DATABASE_URL="postgresql://ceinfua:ceinfua@127.0.0.1:5432/ceinfua?schema=public"

# NextAuth
NEXTAUTH_SECRET="replace-with-a-random-secret-run-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Seed script (npx prisma db seed) — sets the password for the bootstrap admin account
ADMIN_SEED_PASSWORD="set-a-real-password-here"

# Resend (transactional email for verification / claim-account invites)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="CEINFUA <no-reply@ceinfua.local>"

# Vercel Blob (image uploads for News/Events) — get a token from the Vercel Blob store dashboard
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your_token"
