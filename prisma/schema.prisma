// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// provider stays "postgresql" when moving to Neon/Supabase for deployment — only DATABASE_URL changes

model News {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  title     String
  body      String
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text"))
  title       String
  description String
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  STUDENT
  CEINFUA_MEMBER
  ADMIN
  EXTERNAL_PARTNER
}

enum Carrera {
  INGENIERIA_INFORMATICA
  LICENCIATURA_ANALISIS_SISTEMAS
}

enum Estado {
  ACTIVO
  EGRESADO
  INACTIVO
}

model User {
  id                  String    @id @default(dbgenerated("gen_random_uuid()::text"))
  email               String    @unique
  passwordHash        String?
  role                Role      @default(STUDENT)
  emailVerifiedAt     DateTime?
  claimToken          String?   @unique
  claimTokenExpiresAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  student Student?
}

model Student {
  id            String   @id @default(dbgenerated("gen_random_uuid()::text"))
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nombre        String
  apellido      String
  cedula        String   @unique
  telefono      String
  carrera       Carrera
  anioIngreso   Int
  estado        Estado   @default(ACTIVO)
  creadoEn      DateTime @default(now()) @map("createdAt")
  actualizadoEn DateTime @updatedAt @map("updatedAt")
}
